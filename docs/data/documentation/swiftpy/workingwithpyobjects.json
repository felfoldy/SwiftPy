{"abstract":[{"type":"text","text":"Hold Python values from Swift and read attributes, call functions, and bridge results back to Swift types."}],"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/PyObject","type":"reference","isActive":true},{"text":" is a safe, reference-counted handle to a Python value. As long as you hold the handle the underlying Python object stays alive, so the reference is always valid and won’t be dereferenced out from under you. When the ","type":"text"},{"code":"PyObject","type":"codeVoice"},{"text":" goes out of scope, the value is released automatically.","type":"text"}]},{"type":"heading","text":"Get a PyObject","anchor":"Get-a-PyObject","level":2},{"type":"paragraph","inlineContent":[{"text":"Evaluate a Python expression and keep its result by asking for a ","type":"text"},{"identifier":"doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/PyObject","type":"reference","isActive":true},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let numbers: PyObject? = Interpreter.evaluate(\"[1, 2, 3]\")"]},{"type":"paragraph","inlineContent":[{"text":"You can also reach into a module to grab one of its members:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let math = py.module(\"math\")","let sqrt = math?.sqrt   \/\/ a PyObject for the function"]},{"type":"heading","text":"Read and write attributes","anchor":"Read-and-write-attributes","level":2},{"type":"paragraph","inlineContent":[{"text":"Python attributes are available through ordinary Swift member syntax. Reading an attribute as a ","type":"text"},{"identifier":"doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/PyObject","type":"reference","isActive":true},{"text":" lets you keep chaining into the value:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let pi = math?.pi   \/\/ PyObject?"]},{"type":"paragraph","inlineContent":[{"text":"Annotate the result with a Swift type to bridge the value across automatically:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let pi: Double? = math?.pi"]},{"type":"paragraph","inlineContent":[{"text":"Assigning to a member writes the attribute back on the Python object:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["py.main.config?.retries = 3"]},{"type":"heading","text":"Call functions","anchor":"Call-functions","level":2},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/PyObject","type":"reference","isActive":true},{"text":" that wraps a callable can be invoked directly. Annotate the result to bridge it to a Swift type:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let root: Double = try math!.sqrt(2.0)"]},{"type":"paragraph","inlineContent":[{"text":"Use a ","type":"text"},{"identifier":"doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/PyObject","type":"reference","isActive":true},{"text":" result when you want to keep working with the return value in Python, or ignore the result entirely when you only care about the side effect:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["try py.main.logger?.info(\"started\")"]},{"type":"paragraph","inlineContent":[{"text":"Calls throw a ","type":"text"},{"identifier":"doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/PythonError","type":"reference","isActive":true},{"text":" if the Python side raises an exception.","type":"text"}]},{"type":"heading","text":"Subscript dictionaries","anchor":"Subscript-dictionaries","level":2},{"type":"paragraph","inlineContent":[{"text":"When a ","type":"text"},{"identifier":"doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/PyObject","type":"reference","isActive":true},{"text":" wraps a dictionary, subscript it by key. As with attributes, you can read the value as another ","type":"text"},{"identifier":"doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/PyObject","type":"reference","isActive":true},{"text":" or bridge it to a Swift type:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let env: PyObject? = Interpreter.evaluate(\"{'name': 'SwiftPy', 'version': 11}\")","let name: String? = env?[\"name\"]","env?[\"version\"] = 12"]}],"kind":"content"}],"sections":[],"kind":"article","metadata":{"roleHeading":"API Collection","modules":[{"name":"SwiftPy"}],"role":"collectionGroup","title":"Working with PyObjects"},"seeAlsoSections":[{"anchor":"Essentials","generated":true,"identifiers":["doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/GettingStarted","doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/CreatingModules","doc:\/\/swiftpy.SwiftPy\/tutorials\/SwiftPyTutorials","doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/Interpreter"],"title":"Essentials"}],"variants":[{"paths":["\/documentation\/swiftpy\/workingwithpyobjects"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy"],["doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy","doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/CreatingModules"]]},"topicSections":[{"anchor":"Related","identifiers":["doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/PyObject","doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/PythonConvertible","doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/Interpreter"],"title":"Related"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/WorkingWithPyObjects","interfaceLanguage":"swift"},"references":{"doc://swiftpy.SwiftPy/documentation/SwiftPy/GettingStarted":{"abstract":[{"type":"text","text":"Welcome to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy"},{"type":"text","text":", a fast and lightweight Python interpreter powered by pocketpy and enhanced with Swift macro binding tools."}],"type":"topic","role":"article","kind":"article","url":"\/documentation\/swiftpy\/gettingstarted","identifier":"doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/GettingStarted","title":"Getting Started"},"doc://swiftpy.SwiftPy/documentation/SwiftPy/PythonError":{"abstract":[],"type":"topic","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PythonError"}],"role":"symbol","url":"\/documentation\/swiftpy\/pythonerror","title":"PythonError","kind":"symbol","identifier":"doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/PythonError","navigatorTitle":[{"kind":"identifier","text":"PythonError"}]},"doc://swiftpy.SwiftPy/documentation/SwiftPy/Interpreter":{"type":"topic","kind":"symbol","url":"\/documentation\/swiftpy\/interpreter","navigatorTitle":[{"kind":"identifier","text":"Interpreter"}],"abstract":[{"type":"text","text":"A Swift interface for interacting with the embedded Python interpreter."}],"title":"Interpreter","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Interpreter"}],"role":"symbol","identifier":"doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy\/Interpreter"},"doc://swiftpy.SwiftPy/documentation/SwiftPy":{"url":"\/documentation\/swiftpy","title":"SwiftPy","type":"topic","abstract":[{"type":"text","text":"A fast and lightweight Python interpreter with Swift macro binding tools."}],"role":"collection","identifier":"doc:\/\/swiftpy.SwiftPy\/documentation\/SwiftPy","kind":"symbol"},"doc://swiftpy.SwiftPy/tutorials/SwiftPyTutorials":{"abstract":[{"type":"text","text":"A fast and lightweight Python interpreter with Swift macro binding tools."}],"type":"topic","role":"overview","kind":"overview","url":"\/tutorials\/swiftpytutorials","identifier":"doc:\/\/swiftpy.SwiftPy\/tutorials\/SwiftPyTutorials","title":"Meet SwiftPy"},"doc://swiftpy.SwiftPy/documentation/SwiftPy/CreatingModules":{"abstract":[{"type":"text","text":"Expose 